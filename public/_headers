# Cloudflare Pages _headers — https://developers.cloudflare.com/pages/configuration/headers/
# Applied automatically on deploy (no dashboard config needed); overrides Cloudflare defaults.

# Content-hashed build assets (the stylesheet): filename changes whenever the
# content changes, so cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Note: non-hashed assets under /images, /badges, favicon.* keep the default TTL on purpose,
# because their URLs are stable while content can change (e.g. cover.svg updates).
